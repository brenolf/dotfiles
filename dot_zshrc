source ~/.config/antigen/antigen.zsh

if [[ -f /opt/homebrew/bin/brew ]]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
fi

antigen bundle git
antigen bundle zsh-users/zsh-autosuggestions
antigen bundle zsh-users/zsh-syntax-highlighting

alias ls="eza --icons=always -l"

antigen apply

zstyle ':completion:*' menu select

eval "$(starship init zsh)"

# --- Machine-specific configuration ---

# Shopify machine — detected by TEC (Shopify's managed dev tooling)
if [[ -d "$HOME/.local/state/tec" ]]; then
    # Personal pi <-> Slack agent (Iara) connection.
    # IARA_USER accepts a comma-separated list so both the handle (what
    # agent-slack returns on enterprise grid) and the W-id work.
    export IARA_CHANNEL=C0AGJKHCB7D
    export IARA_USER=breno.limadefreitas,W018GAGDCVB

    # Keep the machine fully awake (no idle sleep, no display sleep).
    alias nosleep="sudo pmset -a disablesleep 1 && sudo pmset -a sleep 0 && sudo pmset -a displaysleep 0 && echo '👎😴'"
    # Restore normal sleep behavior (reverse of nosleep).
    alias yessleep="sudo pmset -a disablesleep 0 && sudo pmset -a sleep 1 && sudo pmset -a displaysleep 10 && echo '👍😴'"
fi

# Home machine (obelisk)
if [[ "$(hostname)" == "obelisk" ]]; then
    alias serverino="ssh 192.168.2.253 -l brenolf"
fi

# Added by tec agent
[[ -x /Users/breno/.local/state/tec/profiles/base/current/global/init ]] && eval "$(/Users/breno/.local/state/tec/profiles/base/current/global/init zsh)"
